<Window x:Name="window" x:Class="GeneratorUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GeneratorUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="117*"/>
            <ColumnDefinition Width="283*"/>
        </Grid.ColumnDefinitions>
        <ProgressBar HorizontalAlignment="Left" Height="15" Margin="10,409,0,0" VerticalAlignment="Top" Width="683" ValueChanged="ProgressBar_ValueChanged" Grid.ColumnSpan="2"/>
        <TabControl Margin="0,68,10,42" Grid.ColumnSpan="2">
            <TabItem Header="TabItem">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
            <TabItem Header="TabItem">
                <Grid Background="#FFE5E5E5" HorizontalAlignment="Left" Width="772" Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <ListView>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn/>
                            </GridView>
                        </ListView.View>
                        <GridView/>
                    </ListView>
                </Grid>
            </TabItem>
        </TabControl>
        <StackPanel HorizontalAlignment="Left" Orientation="Vertical" VerticalAlignment="Center"/>
        <ToolBarTray x:Name="toolBarTray" Height="29" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5" Margin="0,0,0,0" Grid.ColumnSpan="2">
            <ToolBarTray.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="{Binding ActualWidth.E, ElementName=window}"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </ToolBarTray.RenderTransform>
            <ToolBar Header="" Margin="0,0,-172,0">
                <Button Content="New"/>
                <Button Content="Open"/>
                <Button Content="Save"/>
                <Button Content="Save As"/>
            </ToolBar>
            <ToolBar Margin="293,1,-423,-1">
                <MenuItem Header="Help" Width="109" HorizontalAlignment="Center"/>
            </ToolBar>
            <ToolBar Margin="178,0,-291,0">
                <Button Content="LLM API Keys"/>
            </ToolBar>
        </ToolBarTray>
    </Grid>
</Window>
