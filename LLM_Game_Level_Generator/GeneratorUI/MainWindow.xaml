<Window x:Name="window" x:Class="GeneratorUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GeneratorUI"
        xmlns:utils="clr-namespace:GeneratorUI.Utils"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
            <RowDefinition Height="Auto"/>
            <!-- Progress bar -->
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <ToolBarTray x:Name="toolBarTray" Grid.Row="0" Grid.Column="0" Height="29" HorizontalAlignment="Left" VerticalAlignment="Top">
                <ToolBarTray.RenderTransform>
                    <TransformGroup>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </ToolBarTray.RenderTransform>
                <ToolBar Header="" Margin="0,0,0,0">
                    <Menu>
                        <MenuItem Header="File">
                            <MenuItem Header="New" Click="newFileButton_Click"/>
                            <MenuItem Header="Open" Click="openFIleButton_Click"/>
                            <MenuItem Header="Save" Click="saveButton_Click"/>
                            <MenuItem Header="Save As" Click="saveAsButton_Click"/>
                        </MenuItem>
                    </Menu>
                </ToolBar>
                <ToolBar>
                    <Menu>
                        <MenuItem Header="View">
                            <MenuItem Header="Zoom In" Click="ZoomInButton_Click"/>
                            <MenuItem Header="Zoom Out" Click="ZoomOutButton_Click"/>
                        </MenuItem>
                    </Menu>
                </ToolBar>
                <ToolBar Margin="0,1,0,-1">
                    <Menu>
                        <MenuItem Header="Help">
                            <MenuItem Header="User Guide"/>
                            <MenuItem Header="About"/>
                        </MenuItem>
                    </Menu>
                </ToolBar>
                <ToolBar Margin="0,0,0,0">
                    <Button Content="LLM API Keys"/>
                </ToolBar>
            </ToolBarTray>

            <Button
                Grid.Row="0"
                Grid.Column="1"
                Content="Optimize"
                HorizontalAlignment="Stretch"
                MinWidth="85"
                MinHeight="29"
                Margin="0,0,0,0"
                VerticalAlignment="Center"
                Background="Teal"
                Foreground="White"
                Click="OptimizeButton_Click"/>
            <Button 
                Grid.Row="0"
                Grid.Column="2"
                Content="Generate"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,0"
                VerticalAlignment="Center"
                MinWidth="85"
                MinHeight="29"
                Background="LawnGreen"
                Click="GenerateButton_Click"/>
        </Grid>



        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="General Information">
                <Grid Background="#FFE5E5E5" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Column="0" Grid.Row="0" Content="Game Name" HorizontalAlignment="Left" Margin="10,10,30,0" VerticalAlignment="Top" Width="88"/>
                    <TextBox 
                        Grid.Column="0" 
                        Grid.Row="0"
                        HorizontalAlignment="Stretch" 
                        Margin="10,36,30,0" 
                        TextWrapping="Wrap" 
                        Text="{Binding GeneralElements.GameName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                        VerticalAlignment="Top" 
                        Width="Auto"
                        utils:WatermarkService.Watermark="Add Game Name..."
                        />

                    <Label Grid.Column="0" Grid.Row="1" Content="Game Description" HorizontalAlignment="Left" Margin="10,10,30,0" VerticalAlignment="Top" Width="137"/>
                    <TextBox 
                        Grid.Column="0" 
                        Grid.Row="1"
                        HorizontalAlignment="Stretch" 
                        Margin="10,35,30,10" 
                        TextWrapping="WrapWithOverflow" 
                        Text="{Binding GeneralElements.GameDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                        VerticalAlignment="Stretch" 
                        Width="Auto" 
                        MinHeight="209" 
                        Height="Auto"
                        utils:WatermarkService.Watermark="Add Game Description..."/>

                    <Label Grid.Column="1" Grid.Row="0" Content="Level Name" HorizontalAlignment="Left" Margin="10,10,30,0" VerticalAlignment="Top" Width="88"/>
                    <TextBox 
                        Grid.Column="1" 
                        Grid.Row="0"
                        HorizontalAlignment="Stretch" 
                        Margin="10,36,30,0" 
                        TextWrapping="Wrap" 
                        Text="{Binding GeneralElements.LevelName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        VerticalAlignment="Top" 
                        Width="Auto"
                        utils:WatermarkService.Watermark="Add Level Name..."/>

                    <Label Grid.Column="1" Grid.Row="1" Content="Level Description" HorizontalAlignment="Left" Margin="10,10,30,0" VerticalAlignment="Top" Width="137"/>
                    <TextBox 
                        Grid.Column="1" 
                        Grid.Row="1"
                        HorizontalAlignment="Stretch" 
                        Margin="10,35,30,10" 
                        TextWrapping="WrapWithOverflow" 
                        Text="{Binding GeneralElements.LevelDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                        VerticalAlignment="Stretch" 
                        Width="Auto" 
                        MinHeight="209" 
                        Height="Auto"
                        utils:WatermarkService.Watermark="Add Level Description..."/>
                </Grid>
            </TabItem>

            <TabItem Header="Tiles" Height="20" VerticalAlignment="Top">
                <Grid Background="#FFE5E5E5" Margin="10,0,0,0" x:Name="tilesGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <ListView Grid.Row="1" x:Name="mapTileList" ItemsSource="{Binding MapTileOptions}" Margin="0,26,0,0">
                        <ListView.Resources>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Validation.HasError" Value="True">
                                        <Setter Property="BorderBrush" Value="Red" />
                                        <Setter Property="BorderThickness" Value="2" />
                                        <Setter Property="ToolTip"
                                                Value="{Binding (Validation.Errors)[0].ErrorContent, 
                                                RelativeSource={RelativeSource Self}}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.Resources>

                        <ListView.View>
                            <GridView x:Name="mapTilesGridView" ColumnHeaderStringFormat="Tiles Information">
                                <GridViewColumn Header="Tile Character" Width="Auto">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Path=TileCharacter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" utils:WatermarkService.Watermark = "Add Character..." MinWidth="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Tile Name" Width="Auto">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Path=TileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" utils:WatermarkService.Watermark = "Add Name..." MinWidth="160"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Tile Description" Width="Auto">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Path=TileDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="WrapWithOverflow" MaxHeight="50" utils:WatermarkService.Watermark = "Add Description..." MinWidth="400" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="1" Content="Delete" x:Name="deleteTileButton" Width="Auto" Height="26" VerticalAlignment="Top" Background="MediumVioletRed" Click="deleteTileButton_Click"/>
                        <Button Grid.Column="0" x:Name="addTileButton" Content="Add Tile" VerticalAlignment="Top" Height="26" Width="Auto" HorizontalAlignment="Stretch" Click="Button_Click" Background="#FF00DFE4"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Constraints">
                <Grid Background="#FFE5E5E5" Margin="0,0,0,0" x:Name="constraintsGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Content="Width" Margin="10,0,0,0"/>
                        <TextBox
                            Grid.Row="0"
                            Text="{Binding MapConstraints.Width, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Margin="10,10,10,0"
                            Height="19"
                            MinWidth="50"
                            HorizontalAlignment="Stretch"/>
                        <Label Grid.Row="1" Content="Height" Margin="10,0,0,0"/>
                        <TextBox
                            Grid.Row="1"
                            Text="{Binding MapConstraints.Height, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Margin="10,10,10,0"
                            Height="19"
                            MinWidth="50"
                            HorizontalAlignment="Stretch"/>
                        <Label Grid.Row="2" Content="Game Type" Margin="10,0,0,0"/>
                        <ComboBox
                            Grid.Row="2"
                            Margin="10,10,10,0"
                            Height="20"
                            MinWidth="50"
                            HorizontalAlignment="Stretch"
                            Background="White"
                            ItemsSource="{Binding ElementName=window, Path=DataContext.GameTypeArray}"
                            SelectedItem="{Binding MapConstraints.GameType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Label Grid.Row="3" Content="Game Genre" Margin="10,0,0,0"/>
                        <TextBox
                            Grid.Row="3"
                            Text="{Binding MapConstraints.GameGenre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Margin="10,10,10,0"
                            Height="19"
                            MinWidth="50"
                            HorizontalAlignment="Stretch"/>
                        <Label Grid.Row="4" Content="Difficulty Level" Margin="10,0,0,0" VerticalAlignment="Top"/>
                        <ComboBox
                            Grid.Row="4"
                            Margin="10,10,10,0"
                            Height="20"
                            MinWidth="50"
                            HorizontalAlignment="Stretch"
                            Background="White"
                            ItemsSource="{Binding ElementName=window, Path=DataContext.DifficultyArray}"
                            SelectedItem="{Binding MapConstraints.DifficultyLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Label Grid.Row="5" Content="Hazards Density" Margin="10,0,0,0" VerticalAlignment="Top"/>
                        <ComboBox
                            Grid.Row="5"
                            Margin="10,10,10,0"
                            Height="20"
                            MinWidth="50"
                            HorizontalAlignment="Stretch"
                            Background="White"
                            ItemsSource="{Binding ElementName=window, Path=DataContext.HazardLevelArray}"
                            SelectedItem="{Binding MapConstraints.HazardDensity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    </Grid>
                    <Label Grid.Column="1" Content="Custom Constraints" Margin="10,0,0,0"/>
                    <TextBox
                        Grid.Column="1"
                        Text="{Binding MapConstraints.CustomConstraints, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Margin="10,25,10,20"
                        MinWidth="50"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"/>


                </Grid>
            </TabItem>

            <TabItem Header="Output">
                <TextBox 
                    IsReadOnly="True"
                    Text="{Binding Output.GeneratedMap, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"/>
            </TabItem>
        </TabControl>

        <ProgressBar
            Grid.Row="2"
            Height="15"
            Margin="10,10,10,10"
            HorizontalAlignment="Stretch"
            x:Name="progressBar1"
            Minimum="0"
            Maximum="100"
            IsIndeterminate="False"/>
    </Grid>
</Window>
