<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:MAUI_UI.Converters"
             x:Class="MAUI_UI.MainPage">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:NullableIntConverter x:Key="NullableIntConverter" />

            <Style x:Key="ActiveTabStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#512BD4, Dark=#ac99ea}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HeightRequest" Value="36" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="12,6" />
            </Style>

            <Style x:Key="InactiveTabStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#C8C8C8, Dark=#404040}" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light=#212121, Dark=#E1E1E1}" />
                <Setter Property="FontAttributes" Value="None" />
                <Setter Property="HeightRequest" Value="36" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="12,6" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">

        <!-- Row 0: Toolbar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" Padding="5">

            <!-- File menu -->
            <Button Grid.Column="0" Text="File"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    FontSize="13"
                    Clicked="ShowFileFlyout_Clicked">
                <FlyoutBase.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="New" Clicked="NewFile_Clicked" />
                        <MenuFlyoutItem Text="Open" Clicked="OpenFile_Clicked" />
                        <MenuFlyoutItem Text="Save" Clicked="Save_Clicked" />
                        <MenuFlyoutItem Text="Save As" Clicked="SaveAs_Clicked" />
                    </MenuFlyout>
                </FlyoutBase.ContextFlyout>
            </Button>

            <!-- View menu -->
            <Button Grid.Column="1" Text="View"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    FontSize="13"
                    Clicked="ShowViewFlyout_Clicked">
                <FlyoutBase.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Zoom In" Clicked="ZoomIn_Clicked" />
                        <MenuFlyoutItem Text="Zoom Out" Clicked="ZoomOut_Clicked" />
                    </MenuFlyout>
                </FlyoutBase.ContextFlyout>
            </Button>

            <!-- Help menu -->
            <Button Grid.Column="2" Text="Help"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    FontSize="13"
                    Clicked="ShowHelpFlyout_Clicked">
                <FlyoutBase.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="User Guide" />
                        <MenuFlyoutItem Text="About" />
                    </MenuFlyout>
                </FlyoutBase.ContextFlyout>
            </Button>

            <Button Grid.Column="3"
                    Text="LLM API Keys"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    FontSize="13" />
            <Button Grid.Column="5"
                    x:Name="optimizeButton"
                    Text="Optimize"
                    BackgroundColor="Teal"
                    TextColor="White"
                    MinimumWidthRequest="85"
                    HeightRequest="32"
                    Clicked="Optimize_Clicked" />
            <Button Grid.Column="6"
                    x:Name="generateButton"
                    Text="Generate"
                    BackgroundColor="LawnGreen"
                    TextColor="Black"
                    MinimumWidthRequest="85"
                    HeightRequest="32"
                    Clicked="Generate_Clicked" />
        </Grid>

        <!-- Row 1: Tab System -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="10">

            <!-- Tab Headers -->
            <HorizontalStackLayout Grid.Row="0" Spacing="2">
                <Button x:Name="tabBtn0" Text="General Information" Clicked="TabButton_Clicked"
                        Style="{StaticResource ActiveTabStyle}" ClassId="0" />
                <Button x:Name="tabBtn1" Text="Tiles" Clicked="TabButton_Clicked"
                        Style="{StaticResource InactiveTabStyle}" ClassId="1" />
                <Button x:Name="tabBtn2" Text="Constraints" Clicked="TabButton_Clicked"
                        Style="{StaticResource InactiveTabStyle}" ClassId="2" />
                <Button x:Name="tabBtn3" Text="Output" Clicked="TabButton_Clicked"
                        Style="{StaticResource InactiveTabStyle}" ClassId="3" />
                <Button x:Name="tabBtn4" Text="LLM Reasoning" Clicked="TabButton_Clicked"
                        Style="{StaticResource InactiveTabStyle}" ClassId="4" />
            </HorizontalStackLayout>

            <!-- Tab 0: General Information -->
            <Grid x:Name="tabPanel0" Grid.Row="1" IsVisible="True"
                  ColumnDefinitions="*,*"
                  RowDefinitions="Auto,*"
                  Padding="10">

                <Label Grid.Column="0" Grid.Row="0" Text="Game Name"
                       Margin="0,0,0,5" />
                <Entry Grid.Column="0" Grid.Row="0" Margin="0,25,15,0"
                       Placeholder="Add Game Name..."
                       Text="{Binding GeneralElements.GameName, Mode=TwoWay}" />

                <Label Grid.Column="0" Grid.Row="1" Text="Game Description"
                       Margin="0,10,0,5" VerticalOptions="Start" />
                <Editor Grid.Column="0" Grid.Row="1" Margin="0,35,15,10"
                        Placeholder="Add Game Description..."
                        Text="{Binding GeneralElements.GameDescription, Mode=TwoWay}"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="200"
                        VerticalOptions="Fill" />

                <Label Grid.Column="1" Grid.Row="0" Text="Level Name"
                       Margin="15,0,0,5" />
                <Entry Grid.Column="1" Grid.Row="0" Margin="15,25,0,0"
                       Placeholder="Add Level Name..."
                       Text="{Binding GeneralElements.LevelName, Mode=TwoWay}" />

                <Label Grid.Column="1" Grid.Row="1" Text="Level Description"
                       Margin="15,10,0,5" VerticalOptions="Start" />
                <Editor Grid.Column="1" Grid.Row="1" Margin="15,35,0,10"
                        Placeholder="Add Level Description..."
                        Text="{Binding GeneralElements.LevelDescription, Mode=TwoWay}"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="200"
                        VerticalOptions="Fill" />
            </Grid>

            <!-- Tab 1: Tiles -->
            <Grid x:Name="tabPanel1" Grid.Row="1" IsVisible="False"
                  RowDefinitions="Auto,Auto,*"
                  Padding="10">

                <!-- Add/Delete buttons -->
                <Grid Grid.Row="0" ColumnDefinitions="*,*" Margin="0,0,0,5">
                    <Button Grid.Column="0" Text="Add Tile"
                            BackgroundColor="#FF00DFE4" TextColor="Black"
                            Clicked="AddTile_Clicked" />
                    <Button Grid.Column="1" Text="Delete"
                            BackgroundColor="MediumVioletRed" TextColor="White"
                            Clicked="DeleteTile_Clicked" />
                </Grid>

                <!-- Column Headers -->
                <Grid Grid.Row="1" ColumnDefinitions="100,160,*,100,100"
                      Padding="5,5,5,2">
                    <Label Grid.Column="0" Text="Character" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="Name" FontAttributes="Bold" />
                    <Label Grid.Column="2" Text="Description" FontAttributes="Bold" />
                    <Label Grid.Column="3" Text="Min Tiles" FontAttributes="Bold" />
                    <Label Grid.Column="4" Text="Max Tiles" FontAttributes="Bold" />
                </Grid>

                <!-- Tile List -->
                <CollectionView Grid.Row="2"
                                x:Name="mapTileCollectionView"
                                ItemsSource="{Binding MapTileOptions}"
                                SelectionMode="Multiple">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="100,160,*,100,100"
                                  Padding="5,2" HeightRequest="40">
                                <Entry Grid.Column="0"
                                       Text="{Binding TileCharacter, Mode=TwoWay}"
                                       Placeholder="Char..." />
                                <Entry Grid.Column="1"
                                       Text="{Binding TileName, Mode=TwoWay}"
                                       Placeholder="Name..." />
                                <Entry Grid.Column="2"
                                       Text="{Binding TileDescription, Mode=TwoWay}"
                                       Placeholder="Description..." />
                                <Entry Grid.Column="3"
                                       Text="{Binding MinimumNumberOfTiles, Mode=TwoWay, Converter={StaticResource NullableIntConverter}}"
                                       Placeholder="Min"
                                       Keyboard="Numeric" />
                                <Entry Grid.Column="4"
                                       Text="{Binding MaximumNumberOfTiles, Mode=TwoWay, Converter={StaticResource NullableIntConverter}}"
                                       Placeholder="Max"
                                       Keyboard="Numeric" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <!-- Tab 2: Constraints -->
            <Grid x:Name="tabPanel2" Grid.Row="1" IsVisible="False"
                  ColumnDefinitions="Auto,*"
                  Padding="10">

                <VerticalStackLayout Grid.Column="0" Spacing="5" WidthRequest="200">
                    <Label Text="Width" />
                    <Entry Text="{Binding MapConstraints.Width, Mode=TwoWay}"
                           Keyboard="Numeric" />

                    <Label Text="Height" />
                    <Entry Text="{Binding MapConstraints.Height, Mode=TwoWay}"
                           Keyboard="Numeric" />

                    <Label Text="Game Type" />
                    <Picker x:Name="gameTypePicker"
                            ItemsSource="{Binding GameTypeArray}"
                            SelectedItem="{Binding MapConstraints.GameType, Mode=TwoWay}" />

                    <Label Text="Game Genre" />
                    <Entry Text="{Binding MapConstraints.GameGenre, Mode=TwoWay}" />

                    <Label Text="Difficulty Level" />
                    <Picker x:Name="difficultyPicker"
                            ItemsSource="{Binding DifficultyArray}"
                            SelectedItem="{Binding MapConstraints.DifficultyLevel, Mode=TwoWay}" />

                    <Label Text="Hazards Density" />
                    <Picker x:Name="hazardPicker"
                            ItemsSource="{Binding HazardLevelArray}"
                            SelectedItem="{Binding MapConstraints.HazardDensity, Mode=TwoWay}" />
                </VerticalStackLayout>

                <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="10,0,0,0">
                    <Label Grid.Row="0" Text="Custom Constraints" />
                    <Editor Grid.Row="1"
                            Text="{Binding MapConstraints.CustomConstraints, Mode=TwoWay}"
                            Placeholder="Add custom constraints..."
                            AutoSize="TextChanges"
                            VerticalOptions="Fill" />
                </Grid>
            </Grid>

            <!-- Tab 3: Output -->
            <Grid x:Name="tabPanel3" Grid.Row="1" IsVisible="False"
                  RowDefinitions="Auto,*">
                <Button Grid.Row="0" Text="Save Map"
                        BackgroundColor="Aquamarine" TextColor="Black"
                        Clicked="SaveMap_Clicked" />
                <Editor Grid.Row="1"
                        x:Name="outputEditor"
                        Margin="5"
                        FontFamily="Consolas"
                        FontSize="20"
                        IsReadOnly="True"
                        Text="{Binding Output.GeneratedMap, Mode=OneWay}"
                        VerticalOptions="Fill"
                        HorizontalOptions="Fill" />
            </Grid>

            <!-- Tab 4: LLM Reasoning -->
            <Grid x:Name="tabPanel4" Grid.Row="1" IsVisible="False"
                  RowDefinitions="*">
                <Editor Grid.Row="0"
                        x:Name="reasoningEditor"
                        Margin="5"
                        FontFamily="Consolas"
                        FontSize="20"
                        IsReadOnly="True"
                        Text="{Binding Output.ReasoningSummary, Mode=OneWay}"
                        VerticalOptions="Fill"
                        HorizontalOptions="Fill" />
            </Grid>
        </Grid>

        <!-- Row 2: Progress Indicator -->
        <ActivityIndicator Grid.Row="2"
                           x:Name="activityIndicator"
                           IsRunning="False"
                           IsVisible="True"
                           HeightRequest="30"
                           Margin="10"
                           HorizontalOptions="Fill"
                           Color="Teal" 
                           BackgroundColor="DarkSlateGrey"/>
    </Grid>
</ContentPage>
